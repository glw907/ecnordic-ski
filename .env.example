# Environment Variables for Hugo + Cloudflare Workers Template
# ============================================================
#
# These variables must be set in Cloudflare Workers dashboard:
#   Workers & Pages > Your Worker > Settings > Variables
#
# IMPORTANT: After adding variables, you must click "Deploy" for them to take effect!
#
# NEVER commit actual secrets to git. This file documents what's needed.

# ──────────────────────────────────────────────────────────────
# CLOUDFLARE TURNSTILE (Spam Protection)
# ──────────────────────────────────────────────────────────────
#
# Get these from: https://dash.cloudflare.com/?to=/:account/turnstile
#
# Site Key (public) - goes in layouts/_default/about.html
#   Production: Create widget, add your domain to allowed hostnames
#   Testing: Use 1x00000000000000000000AA (works on any domain)
#
# Secret Key (private) - set in Cloudflare dashboard as encrypted variable
#   Production: Copy from Turnstile widget settings
#   Testing: Worker auto-detects test tokens, no secret needed

TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ──────────────────────────────────────────────────────────────
# CONTACT EMAIL (Destination)
# ──────────────────────────────────────────────────────────────
#
# Email address where contact form submissions will be sent.
# Set as plain text variable (not encrypted).

CONTACT_EMAIL=you@example.com

# ──────────────────────────────────────────────────────────────
# RESEND API KEY (Email Sending)
# ──────────────────────────────────────────────────────────────
#
# Resend is the email service (MailChannels discontinued August 2024).
# Free tier: 3,000 emails/month (100/day)
#
# To get a Resend API key:
# 1. Sign up at https://resend.com
# 2. Go to API Keys in the dashboard
# 3. Create a new API key
# 4. Copy the key (starts with "re_")
#
# Set as encrypted variable in Cloudflare dashboard.
#
# DOMAIN VERIFICATION (Optional for testing):
# - Testing: Worker uses onboarding@resend.dev as sender (works immediately)
# - Production: Verify your domain in Resend, then update src/worker.js

RESEND_API_KEY=re_your_api_key_here

# ──────────────────────────────────────────────────────────────
# OPTIONAL: HUGO VERSION
# ──────────────────────────────────────────────────────────────
#
# Override the Hugo version in build.sh (useful for testing newer versions)
# Set as Build Variable (not regular variable) if needed.

# HUGO_VERSION=0.123.7

# ──────────────────────────────────────────────────────────────
# HOW TO SET IN CLOUDFLARE DASHBOARD
# ──────────────────────────────────────────────────────────────
#
# 1. Go to: Cloudflare Dashboard > Compute (Workers) > Workers & Pages
# 2. Select your worker
# 3. Go to: Settings > Variables
# 4. Add variables:
#    - TURNSTILE_SECRET_KEY (type: Encrypted)
#    - CONTACT_EMAIL (type: Plain text)
#    - RESEND_API_KEY (type: Encrypted)
# 5. Click "Deploy" to apply changes
#
# ALTERNATIVE: Using Wrangler CLI
# ──────────────────────────────────────────────────────────────
#
# npx wrangler login
# npx wrangler secret put TURNSTILE_SECRET_KEY
# npx wrangler secret put RESEND_API_KEY
# npx wrangler secret put CONTACT_EMAIL

# ──────────────────────────────────────────────────────────────
# TESTING QUICK START
# ──────────────────────────────────────────────────────────────
#
# For fastest testing on workers.dev domain:
#
# 1. Set Turnstile testing site key in about.html:
#    data-sitekey="1x00000000000000000000AA"
#
# 2. Create Resend account, get API key
#
# 3. Add to Cloudflare:
#    - RESEND_API_KEY = re_your_key (encrypted)
#    - CONTACT_EMAIL = your@email.com (plain text)
#
# 4. Click Deploy
#
# That's it! Contact form will work with test Turnstile and
# send emails via onboarding@resend.dev
